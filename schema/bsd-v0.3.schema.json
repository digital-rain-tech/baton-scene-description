{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://batonscene.dev/schema/bsd-v0.3.schema.json",
  "title": "Baton Scene Description v0.3",
  "description": "A typed interchange schema for cinematic directorial intent. v0.3 adds character interactions, character modes, reference images, structured dialogue, and narrative function. The schema has two layers: SessionContext (established once per session) and BeatDescription (produced every interpretation tick).",
  "type": "object",
  "required": [
    "version", "session_id", "beat_id", "sequence_num", "timestamp_ms",
    "camera", "lighting", "characters", "interactions", "environment",
    "mood", "mood_intensity", "flow_control",
    "dialogue_lines", "reference_images", "negative_prompts", "direction_notes"
  ],
  "properties": {
    "version": { "const": "0.3" },
    "session_id": { "type": "string" },
    "beat_id": { "type": "string" },
    "sequence_num": { "type": "integer", "minimum": 0 },
    "timestamp_ms": { "type": "number" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "narrative_function": { "$ref": "#/$defs/NarrativeFunction" },
    "camera": { "$ref": "#/$defs/CameraState" },
    "lighting": { "$ref": "#/$defs/LightingState" },
    "characters": {
      "type": "array",
      "items": { "$ref": "#/$defs/CharacterBeatStateV3" }
    },
    "interactions": {
      "type": "array",
      "items": { "$ref": "#/$defs/Interaction" }
    },
    "environment": { "$ref": "#/$defs/EnvironmentBeatState" },
    "mood": { "type": "string" },
    "mood_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
    "flow_control": { "$ref": "#/$defs/FlowControl" },
    "transition": { "$ref": "#/$defs/TransitionState" },
    "dialogue_lines": {
      "type": "array",
      "items": { "$ref": "#/$defs/DialogueLine" }
    },
    "reference_images": {
      "type": "array",
      "items": { "$ref": "#/$defs/ReferenceImage" }
    },
    "negative_prompts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "direction_notes": { "type": "string" }
  },
  "additionalProperties": false,
  "$defs": {
    "CameraMovement": {
      "type": "string",
      "enum": [
        "static", "pan_left", "pan_right", "whip_pan",
        "tilt_up", "tilt_down", "pedestal_up", "pedestal_down",
        "truck_left", "truck_right", "dolly_in", "dolly_out",
        "zoom_in", "zoom_out", "dolly_zoom",
        "crane_up", "crane_down", "tracking",
        "arc_left", "arc_right", "steadicam", "handheld"
      ]
    },
    "CameraAngle": {
      "type": "string",
      "enum": [
        "eye_level", "low_angle", "high_angle", "birds_eye",
        "worms_eye", "dutch_angle", "over_the_shoulder", "pov"
      ]
    },
    "ShotType": {
      "type": "string",
      "enum": [
        "extreme_wide", "wide", "full", "medium_wide", "medium",
        "medium_close_up", "close_up", "extreme_close_up",
        "insert", "two_shot"
      ]
    },
    "SubjectPosition": {
      "type": "string",
      "enum": ["center", "left_third", "right_third", "lower_third", "upper_third"]
    },
    "DepthOfField": {
      "type": "string",
      "enum": ["shallow", "medium", "deep"]
    },
    "CameraState": {
      "type": "object",
      "required": ["movement", "movement_speed", "angle", "shot_type", "composition"],
      "properties": {
        "movement": { "$ref": "#/$defs/CameraMovement" },
        "movement_speed": { "type": "number", "minimum": 0, "maximum": 1 },
        "angle": { "$ref": "#/$defs/CameraAngle" },
        "shot_type": { "$ref": "#/$defs/ShotType" },
        "composition": {
          "type": "object",
          "required": ["subject_position", "depth_of_field", "headroom", "look_room"],
          "properties": {
            "subject_position": { "$ref": "#/$defs/SubjectPosition" },
            "depth_of_field": { "$ref": "#/$defs/DepthOfField" },
            "headroom": { "type": "number", "minimum": 0, "maximum": 1 },
            "look_room": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "LightRole": {
      "type": "string",
      "enum": ["key", "fill", "back", "rim", "ambient", "practical"]
    },
    "LightQuality": {
      "type": "string",
      "enum": ["hard", "soft"]
    },
    "LightDirection": {
      "type": "string",
      "enum": [
        "front", "three_quarter_left", "three_quarter_right",
        "side_left", "side_right", "back", "top", "under"
      ]
    },
    "LightSource": {
      "type": "object",
      "required": ["role", "quality", "direction", "intensity", "color_temp_k"],
      "properties": {
        "role": { "$ref": "#/$defs/LightRole" },
        "quality": { "$ref": "#/$defs/LightQuality" },
        "direction": { "$ref": "#/$defs/LightDirection" },
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "color_temp_k": { "type": "number" }
      },
      "additionalProperties": false
    },
    "LightingStyle": {
      "type": "string",
      "enum": ["high_key", "low_key", "chiaroscuro", "motivated", "natural", "silhouette"]
    },
    "TimeOfDay": {
      "type": "string",
      "enum": [
        "dawn", "golden_hour_morning", "midday", "overcast",
        "golden_hour_evening", "dusk", "night", "candlelight"
      ]
    },
    "LightingState": {
      "type": "object",
      "required": ["sources", "style", "time_of_day", "color_temp_k", "contrast_ratio"],
      "properties": {
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/LightSource" }
        },
        "style": { "$ref": "#/$defs/LightingStyle" },
        "time_of_day": { "$ref": "#/$defs/TimeOfDay" },
        "color_temp_k": { "type": "number" },
        "contrast_ratio": { "type": "number" }
      },
      "additionalProperties": false
    },
    "FlowControl": {
      "type": "string",
      "enum": [
        "action", "cut", "hold", "resume", "slow_down",
        "speed_up", "new_take", "playback", "lock"
      ]
    },
    "EnvironmentMode": {
      "type": "string",
      "enum": ["camera", "imagined"]
    },
    "EnvironmentBeatState": {
      "type": "object",
      "required": ["mode", "description", "weather", "time_period", "interior_exterior"],
      "properties": {
        "location_ref": { "type": "string" },
        "mode": { "$ref": "#/$defs/EnvironmentMode" },
        "description": { "type": "string" },
        "weather": { "type": "string" },
        "time_period": { "type": "string" },
        "interior_exterior": {
          "type": "string",
          "enum": ["interior", "exterior", "mixed"]
        }
      },
      "additionalProperties": false
    },
    "TransitionType": {
      "type": "string",
      "enum": ["cut", "dissolve", "fade_to_black", "fade_from_black", "wipe", "match_cut"]
    },
    "TransitionState": {
      "type": "object",
      "required": ["type", "duration_seconds"],
      "properties": {
        "type": { "$ref": "#/$defs/TransitionType" },
        "duration_seconds": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "NarrativeFunction": {
      "type": "string",
      "enum": ["setup", "development", "turn", "resolution"]
    },
    "InteractionType": {
      "type": "string",
      "enum": [
        "combat", "conversation", "physical_contact", "chase",
        "standoff", "collaboration", "observation"
      ]
    },
    "Interaction": {
      "type": "object",
      "required": ["participants", "type", "choreography"],
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "type": { "$ref": "#/$defs/InteractionType" },
        "choreography": { "type": "string" },
        "dominance": { "type": "string" },
        "props": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ReferenceAnchorType": {
      "type": "string",
      "enum": ["style", "pose", "composition", "continuity"]
    },
    "ReferenceImage": {
      "type": "object",
      "required": ["anchor_type", "description"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "data_uri": { "type": "string" },
        "anchor_type": { "$ref": "#/$defs/ReferenceAnchorType" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "DialogueLine": {
      "type": "object",
      "required": ["speaker_ref", "line"],
      "properties": {
        "speaker_ref": { "type": "string" },
        "line": { "type": "string" },
        "delivery_note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "CharacterBeatStateV3": {
      "type": "object",
      "required": [
        "character_ref", "emotional_state", "emotional_intensity",
        "action", "blocking", "is_speaking", "dialogue", "performance_note"
      ],
      "properties": {
        "character_ref": { "type": "string" },
        "active_mode": { "type": "string" },
        "emotional_state": { "type": "string" },
        "emotional_intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "action": { "type": "string" },
        "blocking": { "type": "string" },
        "is_speaking": { "type": "boolean" },
        "dialogue": { "type": "string" },
        "performance_note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "SessionContextV3": {
      "title": "Session Context v0.3",
      "description": "Established once per session. Contains the world bible, character/location registries, style guide, and consistency anchors.",
      "type": "object",
      "required": [
        "version", "session_id", "created_at", "world_description",
        "style", "characters", "locations", "anchors", "drift_repairs"
      ],
      "properties": {
        "version": { "const": "0.3" },
        "session_id": { "type": "string" },
        "created_at": { "type": "number" },
        "title": { "type": "string" },
        "world_description": { "type": "string" },
        "style": { "$ref": "#/$defs/StyleGuide" },
        "characters": {
          "type": "array",
          "items": { "$ref": "#/$defs/CharacterDefinitionV3" }
        },
        "locations": {
          "type": "array",
          "items": { "$ref": "#/$defs/LocationDefinition" }
        },
        "anchors": { "$ref": "#/$defs/ConsistencyAnchors" },
        "drift_repairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/DriftRepair" }
        }
      },
      "additionalProperties": false
    },
    "StyleGuide": {
      "type": "object",
      "required": ["visual_style", "color_palette", "material_vocabulary", "global_negative_prompts"],
      "properties": {
        "visual_style": { "type": "string" },
        "photography_style": { "type": "string" },
        "color_palette": {
          "type": "object",
          "required": ["primary", "accent", "description"],
          "properties": {
            "primary": { "type": "array", "items": { "type": "string" } },
            "accent": { "type": "array", "items": { "type": "string" } },
            "description": { "type": "string" }
          },
          "additionalProperties": false
        },
        "material_vocabulary": { "type": "array", "items": { "type": "string" } },
        "global_negative_prompts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "CharacterDefinitionV3": {
      "type": "object",
      "required": ["id", "name", "description", "visual_anchors", "default_emotion"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "scale": { "type": "string" },
        "visual_anchors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["item", "required"],
            "properties": {
              "item": { "type": "string" },
              "required": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "default_emotion": { "type": "string" },
        "modes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "description", "visual_delta"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "visual_delta": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "default_mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "LocationDefinition": {
      "type": "object",
      "required": ["id", "name", "description", "materials"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "materials": { "type": "array", "items": { "type": "string" } },
        "established_lighting": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ConsistencyAnchors": {
      "type": "object",
      "required": ["character_rules", "material_rules", "style_rules", "prohibitions"],
      "properties": {
        "character_rules": { "type": "array", "items": { "type": "string" } },
        "material_rules": { "type": "array", "items": { "type": "string" } },
        "style_rules": { "type": "array", "items": { "type": "string" } },
        "prohibitions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "DriftRepair": {
      "type": "object",
      "required": ["failure_mode", "correction"],
      "properties": {
        "failure_mode": { "type": "string" },
        "correction": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
